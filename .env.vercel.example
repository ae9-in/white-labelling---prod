# Copy these to Vercel Environment Variables Dashboard
# Go to: Project Settings → Environment Variables

# ============================================
# REQUIRED VARIABLES
# ============================================

# Environment
NODE_ENV=production

# Database - REPLACE WITH YOUR MONGODB CONNECTION STRING
# Get from: https://cloud.mongodb.com → Database → Connect
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/white-label-admin?retryWrites=true&w=majority

# Server Port
PORT=5000

# CORS - Allow all origins (or set to your domain)
CORS_ORIGIN=*

# ============================================
# OPTIONAL VARIABLES
# ============================================

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Cron Security (Optional - for securing cron endpoint)
CRON_SECRET=your-random-secret-key-123

# ============================================
# EXAMPLE MONGODB CONNECTION STRING
# ============================================
# mongodb+srv://whitelabel_admin:MyP@ssw0rd123@cluster0.abc123.mongodb.net/white-label-admin?retryWrites=true&w=majority
#
# Format:
# mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
#
# Replace:
# - USERNAME: Your MongoDB username
# - PASSWORD: Your MongoDB password
# - CLUSTER: Your cluster address (e.g., cluster0.abc123)
# - DATABASE: white-label-admin
